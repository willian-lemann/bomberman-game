# Modelo do .env — copie para .env e ajuste: cp .env.example .env

# Ambiente: development | production (decide qual banco SQLite usar)
NODE_ENV=development

# Porta do servidor (HTTP + WebSocket)
PORT=3001

# Caminho do banco SQLite — se vazio/ausente, usa o padrão por ambiente:
#   development -> bomberman.dev.db | production -> bomberman.prod.db
# DB_PATH=/caminho/para/bomberman.db
